{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/forge/agent-index.schema.json",
  "title": "Forge Agent Index",
  "type": "object",
  "required": ["schema_version", "task_id", "status", "agents", "tasks"],
  "properties": {
    "schema_version": { "type": "string" },
    "task_id": { "type": "string", "minLength": 1 },
    "status": { "$ref": "#/$defs/status" },
    "workspace": { "type": "string" },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/agent" }
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    },
    "write_locks": {
      "type": "array",
      "items": { "$ref": "#/$defs/write_lock" }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "array", "items": { "type": "string" } }
        ]
      }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["planned", "ready", "running", "blocked", "needs_review", "done", "failed"]
    },
    "string_list": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "agent": {
      "type": "object",
      "required": ["id", "role", "model", "goal", "allowed_files", "forbidden_files", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "goal": { "type": "string", "minLength": 1 },
        "allowed_files": { "$ref": "#/$defs/string_list" },
        "forbidden_files": { "$ref": "#/$defs/string_list" },
        "status": { "$ref": "#/$defs/status" },
        "evidence": { "$ref": "#/$defs/string_list" },
        "artifacts": { "$ref": "#/$defs/string_list" }
      },
      "additionalProperties": true
    },
    "task": {
      "type": "object",
      "required": ["id", "title", "assigned_agent", "goal", "input", "output", "status", "dependencies", "acceptance"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "assigned_agent": { "type": "string", "minLength": 1 },
        "goal": { "type": "string", "minLength": 1 },
        "input": { "$ref": "#/$defs/string_list" },
        "output": { "$ref": "#/$defs/string_list" },
        "status": { "$ref": "#/$defs/status" },
        "dependencies": { "$ref": "#/$defs/string_list" },
        "acceptance": { "$ref": "#/$defs/string_list" },
        "evidence": { "$ref": "#/$defs/string_list" },
        "artifacts": { "$ref": "#/$defs/string_list" }
      },
      "additionalProperties": true
    },
    "write_lock": {
      "type": "object",
      "required": ["path", "owner"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
